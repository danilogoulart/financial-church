---
import '@fontsource-variable/inter'
import '@fontsource-variable/fraunces'
import { getMenuPages } from '../lib/content'

const { title, description, image } = Astro.props

const menuPages = await getMenuPages()

const CHURCH = 'Igreja AD Alpha'
const FULL = 'Igreja Assembleia de Deus Alpha Ministério Central Praia Linda'
const ADDR = 'Rua Rio de Janeiro, N°6 - Praia Linda, São Pedro Da Aldeia - Rio de Janeiro - Brasil'

const pageTitle = title ? `${title} — ${CHURCH}` : `${CHURCH} — ${FULL}`
const desc = description || `Site oficial da ${FULL}. Notícias, eventos e estudos bíblicos.`

const nav = [
  { href: '/', label: 'Início' },
  ...menuPages.map((p) => ({ href: `/${p.slug}`, label: p.title })),
  { href: '/noticias', label: 'Notícias' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/estudos', label: 'Estudos Bíblicos' }
]
const path = Astro.url.pathname
const isActive = (href) => (href === '/' ? path === '/' : path.startsWith(href))
const year = new Date().getFullYear()
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/logo.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">
          <img src="/logo.png" alt={CHURCH} class="logo" />
          <span class="brand-name">{CHURCH}</span>
        </a>
        <button class="nav-toggle" aria-label="Abrir menu" aria-expanded="false" aria-controls="site-nav">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav" id="site-nav">
          {nav.map((n) => (
            <a href={n.href} class={isActive(n.href) ? 'active' : ''}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <div class="nav-backdrop" hidden></div>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-grid">
        <div>
          <strong>{FULL}</strong>
          <p>{ADDR}</p>
        </div>
        <nav class="footer-links">
          <a href="/noticias">Notícias</a>
          <a href="/eventos">Eventos</a>
          <a href="/estudos">Estudos Bíblicos</a>
          <a href="/admin">Área administrativa</a>
        </nav>
      </div>
      <div class="wrap">
        <p class="muted">© {year} {CHURCH}. Todos os direitos reservados.</p>
      </div>
    </footer>

    <script>
      // Animação do header no scroll: encolhe/ganha blur ao rolar; esconde
      // ao descer e reaparece ao subir (não esconde com o menu aberto).
      const header = document.querySelector('.site-header')
      if (header) {
        let last = window.scrollY
        const onScroll = () => {
          const y = window.scrollY
          header.classList.toggle('scrolled', y > 16)
          if (header.classList.contains('nav-open')) return
          if (y > 240 && y > last + 4) header.classList.add('hidden')
          else if (y < last - 4 || y < 240) header.classList.remove('hidden')
          last = y
        }
        window.addEventListener('scroll', onScroll, { passive: true })
        onScroll()

        // Menu mobile (hambúrguer)
        const toggle = header.querySelector('.nav-toggle')
        const backdrop = document.querySelector('.nav-backdrop')
        const setOpen = (open) => {
          header.classList.toggle('nav-open', open)
          toggle?.setAttribute('aria-expanded', open ? 'true' : 'false')
          toggle?.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu')
          if (backdrop) {
            if (open) { backdrop.hidden = false; requestAnimationFrame(() => backdrop.classList.add('show')) }
            else { backdrop.classList.remove('show'); setTimeout(() => (backdrop.hidden = true), 300) }
          }
        }
        toggle?.addEventListener('click', () => setOpen(!header.classList.contains('nav-open')))
        backdrop?.addEventListener('click', () => setOpen(false))
        header.querySelectorAll('.nav a').forEach((a) => a.addEventListener('click', () => setOpen(false)))
        window.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false) })
        // Ao voltar pro desktop, garante o menu fechado.
        matchMedia('(min-width: 761px)').addEventListener('change', (e) => { if (e.matches) setOpen(false) })
      }
    </script>

    <style is:global>
      :root {
        --bg: #ffffff;
        --ink: #16181b;             /* quase-preto frio */
        --muted: #6d7279;
        --line: #e4e6e9;            /* cinza frio */
        --header: #0e0f11;          /* preto do topo */
        --accent: #23262b;          /* grafite — botões/links */
        --accent-ink: #000000;      /* hover */
        --steel: #8b9199;           /* prata — detalhes/eyebrow */
        --surface: #f3f4f6;         /* cinza claro frio */
        --chrome: linear-gradient(180deg, #f4f5f7 0%, #c7ccd2 48%, #eef0f2 52%, #aab0b7 100%);
        --radius: 16px;
        --wrap: 1080px;
        --sans: 'Inter Variable', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --serif: 'Fraunces Variable', Georgia, 'Times New Roman', serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--sans);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 22px; }
      a { color: inherit; }
      img { max-width: 100%; display: block; }

      h1, h2, h3 {
        font-family: var(--serif);
        font-optical-sizing: auto;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.15;
      }

      /* Header — animações no scroll: encolhe + blur, esconde ao descer. */
      .site-header {
        background: var(--header);
        color: #fff;
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid rgba(255,255,255,.07);
        will-change: transform;
        transition: transform .4s cubic-bezier(.4,0,.2,1), background .3s ease,
                    box-shadow .3s ease, border-color .3s ease;
      }
      .site-header.scrolled {
        background: rgba(14,15,17,.72);
        backdrop-filter: saturate(150%) blur(12px);
        -webkit-backdrop-filter: saturate(150%) blur(12px);
        box-shadow: 0 8px 30px rgba(0,0,0,.28);
        border-color: rgba(255,255,255,.04);
      }
      .site-header.hidden { transform: translateY(-100%); }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        min-height: 84px;
        flex-wrap: wrap;
        transition: min-height .3s ease;
      }
      .site-header.scrolled .header-inner { min-height: 60px; }
      .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #fff; }
      .brand .logo { height: 42px; width: auto; transition: height .3s ease; }
      .site-header.scrolled .brand .logo { height: 32px; }
      .brand-name {
        font-family: var(--sans);
        font-weight: 700;
        font-size: 17px;
        text-transform: uppercase;
        letter-spacing: .22em;
        color: #f2f3f5;
      }
      .nav { display: flex; gap: 4px; flex-wrap: wrap; }
      .nav a {
        text-decoration: none;
        color: #c8ccd1;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: .02em;
        transition: background .15s ease, color .15s ease;
      }
      .nav a:hover { color: #fff; background: rgba(255,255,255,.1); }
      .nav a.active { background: var(--chrome); color: #1a1c1f; font-weight: 600; }

      /* Botão hambúrguer (só no mobile) */
      .nav-toggle {
        display: none;
        position: relative;
        z-index: 31;
        width: 44px;
        height: 44px;
        border: 0;
        background: transparent;
        cursor: pointer;
        padding: 0;
      }
      .nav-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        margin: 5px auto;
        background: #fff;
        border-radius: 2px;
        transition: transform .3s ease, opacity .2s ease;
      }
      .site-header.nav-open .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .site-header.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
      .site-header.nav-open .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      .nav-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        z-index: 20;
        opacity: 0;
        transition: opacity .3s ease;
      }
      .nav-backdrop.show { opacity: 1; }

      @media (max-width: 760px) {
        .nav-toggle { display: block; }
        .header-inner { min-height: 64px; flex-wrap: nowrap; }
        .site-header.scrolled .header-inner { min-height: 56px; }
        .brand-name { font-size: 15px; letter-spacing: .12em; }

        .nav {
          position: fixed;
          top: 0;
          right: 0;
          height: 100dvh;
          width: min(80vw, 320px);
          background: #0e0f11;
          border-left: 1px solid rgba(255,255,255,.08);
          box-shadow: -20px 0 60px rgba(0,0,0,.4);
          flex-direction: column;
          align-items: stretch;
          gap: 4px;
          padding: 88px 20px 24px;
          transform: translateX(100%);
          transition: transform .32s cubic-bezier(.4,0,.2,1);
          z-index: 25;
          overflow-y: auto;
        }
        .site-header.nav-open .nav { transform: translateX(0); }
        .nav a {
          font-size: 17px;
          padding: 14px 16px;
          border-radius: 10px;
        }
        .nav a.active { background: rgba(255,255,255,.14); color: #fff; }
      }

      /* Sections */
      main { padding: 40px 22px 64px; }
      section + section { margin-top: 56px; }
      .section-head {
        display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
        margin: 0 0 22px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--line);
      }
      h1 { font-size: clamp(30px, 5vw, 40px); margin: 0 0 10px; }
      h2 { font-size: clamp(23px, 3.5vw, 28px); margin: 0; }
      .lead { color: var(--muted); font-size: 18px; margin: 0; }
      .link-all { color: var(--ink); text-decoration: none; font-weight: 600; font-size: 15px; white-space: nowrap; border-bottom: 2px solid var(--steel); padding-bottom: 2px; }
      .link-all:hover { border-color: var(--ink); }

      /* Hero — o url(/hero.jpg) é opcional: se o arquivo não existir, ficam
         só os gradientes (banner escuro elegante). Para pôr uma foto, salve
         em site/public/hero.jpg. */
      .hero {
        position: relative;
        overflow: hidden;
        background-color: #1b1712;
        background-image:
          radial-gradient(1200px 400px at 80% -10%, rgba(176,135,63,.30), transparent 60%),
          linear-gradient(150deg, rgba(20,17,13,.86) 0%, rgba(28,24,18,.78) 55%, rgba(20,16,11,.9) 100%),
          url('/hero.jpg');
        background-size: cover;
        background-position: center;
        color: #fff;
        border-radius: 24px;
        padding: clamp(56px, 9vw, 104px) clamp(28px, 5vw, 56px);
      }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
      .hero-actions .btn { margin-top: 0; }
      .btn.on-dark { background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.28); }
      .btn.on-dark:hover { background: rgba(255,255,255,.2); }
      .hero .eyebrow {
        font-family: var(--sans);
        text-transform: uppercase;
        letter-spacing: .18em;
        font-size: 13px;
        font-weight: 600;
        color: var(--accent);
        margin: 0 0 14px;
      }
      .hero h1 { font-size: clamp(34px, 6vw, 56px); color: #fff; max-width: 15ch; }
      .hero p { color: #ded7cc; font-size: clamp(17px, 2.2vw, 20px); max-width: 620px; margin: 16px 0 0; }

      /* Buttons */
      .btn {
        display: inline-block;
        background: var(--accent);
        color: #fff;
        text-decoration: none;
        padding: 13px 26px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 16px;
        margin-top: 22px;
        transition: transform .12s ease, background .15s ease, box-shadow .15s ease;
      }
      .btn:hover { background: var(--accent-ink); transform: translateY(-1px); box-shadow: 0 8px 22px rgba(0,0,0,.18); }
      .btn.ghost { background: transparent; border: 1px solid var(--line); color: var(--ink); margin-top: 0; }
      .btn.ghost:hover { background: var(--surface); }

      /* Card grid */
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 22px; }
      .card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
      }
      a.card { text-decoration: none; color: inherit; }
      a.card:hover { box-shadow: 0 14px 40px rgba(20,17,13,.12); transform: translateY(-3px); border-color: #e0d8cc; }
      .card .thumb { aspect-ratio: 16 / 22; object-fit: cover; width: 100%; background: var(--surface); }
      .card .body { padding: 18px 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
      .card h3 { margin: 0; font-size: 20px; }
      .card .meta { color: var(--muted); font-size: 14px; }
      .card p { margin: 0; color: #4a443c; font-size: 15px; }

      .tag { display: inline-block; font-size: 12px; color: var(--steel); font-weight: 700; text-transform: uppercase; letter-spacing: .12em; }

      /* Imagem de card mostrada por completo (flyers verticais de evento). */
      .card .thumb-full { width: 100%; aspect-ratio: 16 / 22; object-fit: cover; background: var(--surface); }

      /* Banners quadrados (1:1, estilo Instagram) */
      .banner-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
      .banner {
        position: relative;
        aspect-ratio: 1 / 1;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid var(--line);
        background: var(--surface);
        display: block;
      }
      .banner img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s ease; }
      a.banner:hover img { transform: scale(1.05); }

      .empty { color: var(--muted); background: var(--surface); border: 1px dashed var(--line); border-radius: var(--radius); padding: 32px; text-align: center; }

      /* Article */
      .article { max-width: 720px; margin: 0 auto; }
      .article h1 { margin-top: 6px; }
      .article .cover { border-radius: 18px; margin: 22px 0 10px; width: 100%; }
      .article .content { font-size: 18.5px; line-height: 1.75; white-space: pre-wrap; color: #302b24; }
      .back { display: inline-block; margin-bottom: 10px; color: var(--muted); text-decoration: none; font-size: 15px; }
      .back:hover { color: var(--ink); }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--line);
        background: var(--surface);
        padding: 36px 0;
        margin-top: 64px;
        font-size: 14px;
      }
      .site-footer strong { font-family: var(--serif); font-size: 16px; }
      .site-footer p { margin: 6px 0; color: #4a443c; }
      .site-footer .muted { color: var(--muted); margin-top: 18px; }
      .footer-grid { display: flex; justify-content: space-between; gap: 28px; flex-wrap: wrap; }
      .footer-links { display: flex; flex-direction: column; gap: 8px; }
      .footer-links a { color: #43474d; text-decoration: none; font-weight: 500; }
      .footer-links a:hover { color: var(--ink); text-decoration: underline; }

      /* Seção "sobre" */
      .about { display: grid; grid-template-columns: 1.3fr 1fr; gap: 40px; align-items: center; }
      .about h2 { margin-bottom: 12px; }
      .about p { font-size: 17px; color: #3d382f; margin: 0 0 12px; }
      .about .about-media {
        aspect-ratio: 4 / 3;
        border-radius: 18px;
        background:
          radial-gradient(600px 300px at 30% 20%, rgba(190,196,204,.18), transparent 60%),
          linear-gradient(160deg, #1a1c1f, #303338);
        display: flex; align-items: center; justify-content: center;
      }
      .about .about-media img { width: 42%; opacity: .95; }

      /* Faixa de cultos */
      .cults-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; }
      .cult {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 22px 20px;
        background: var(--surface);
        text-align: center;
      }
      .cult .day { font-family: var(--serif); font-size: 21px; font-weight: 600; }
      .cult .desc { color: var(--muted); font-size: 14px; margin-top: 4px; }

      /* Localização + mapa */
      .location { display: grid; grid-template-columns: 1fr 1.1fr; gap: 32px; align-items: stretch; }
      .location .info { display: flex; flex-direction: column; justify-content: center; }
      .location .info p { color: #3d382f; font-size: 17px; }
      .map-embed {
        border: 0;
        width: 100%;
        min-height: 320px;
        height: 100%;
        border-radius: 18px;
        display: block;
        filter: grayscale(.15);
      }

      @media (max-width: 780px) {
        .about, .location { grid-template-columns: 1fr; }
        .about .about-media { order: -1; }
        .map-embed { min-height: 260px; }
      }
    </style>
  </body>
</html>
