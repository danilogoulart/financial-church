---
// Carrossel do topo da home. Cada slide aceita uma imagem opcional em
// site/public (slide1.jpg, slide2.jpg, slide3.jpg); sem o arquivo, fica um
// fundo escuro elegante com leve brilho prateado.
const slides = [
  {
    img: '/slide1.jpg',
    eyebrow: 'Bem-vindo',
    title: 'Uma casa de fé, comunhão e palavra',
    text: 'Um lugar para adorar a Deus, crescer na fé e caminhar em comunidade.',
    cta: 'Próximos eventos',
    href: '/eventos'
  },
  {
    img: '/slide2.jpg',
    eyebrow: 'Venha participar',
    title: 'Cultos durante toda a semana',
    text: 'Domingos, terças e quintas — há sempre um encontro esperando por você.',
    cta: 'Ver programação',
    href: '#localizacao'
  },
  {
    img: '/slide3.jpg',
    eyebrow: 'Cresça na Palavra',
    title: 'Estudos bíblicos para todas as idades',
    text: 'Aprofunde sua caminhada com ensino sólido e acessível.',
    cta: 'Ver estudos',
    href: '/estudos'
  }
]
---

<section class="carousel" aria-label="Destaques" aria-roledescription="carrossel">
  <div class="slides">
    {slides.map((s, i) => (
      <article
        class:list={['slide', { active: i === 0 }]}
        style={`background-image: linear-gradient(to right, rgba(10,11,13,.82), rgba(10,11,13,.35)), var(--slide-img, none); --slide-img: url('${s.img}')`}
      >
        <div class="slide-inner wrap">
          <p class="c-eyebrow">{s.eyebrow}</p>
          <h1 class="c-title">{s.title}</h1>
          <p class="c-text">{s.text}</p>
          <a class="btn" href={s.href}>{s.cta}</a>
        </div>
      </article>
    ))}
  </div>

  <button class="c-arrow prev" aria-label="Slide anterior">‹</button>
  <button class="c-arrow next" aria-label="Próximo slide">›</button>

  <div class="c-dots">
    {slides.map((_, i) => (
      <button class:list={['c-dot', { active: i === 0 }]} data-i={i} aria-label={`Ir para o slide ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  /* full-bleed: quebra o padding do <main class="wrap"> */
  .carousel {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: -40px;
    margin-bottom: 80px;
    overflow: hidden;
    background: #0e0f11;
  }
  .slides { position: relative; height: clamp(440px, 72vh, 660px); }
  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #14161a;
    display: flex;
    align-items: center;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 1s ease, transform 6s ease;
    pointer-events: none;
  }
  .slide.active { opacity: 1; transform: scale(1); pointer-events: auto; }

  .slide-inner { color: #fff; max-width: var(--wrap); }
  .c-eyebrow {
    text-transform: uppercase;
    letter-spacing: .22em;
    font-size: 13px;
    font-weight: 600;
    color: #cfd3d8;
    margin: 0 0 14px;
    opacity: 0;
    transform: translateY(14px);
  }
  .c-title {
    font-family: var(--serif);
    font-size: clamp(34px, 6vw, 60px);
    line-height: 1.08;
    color: #fff;
    max-width: 16ch;
    margin: 0;
    opacity: 0;
    transform: translateY(18px);
  }
  .c-text {
    font-size: clamp(16px, 2.2vw, 20px);
    color: #dfe2e6;
    max-width: 540px;
    margin: 16px 0 0;
    opacity: 0;
    transform: translateY(18px);
  }
  .slide .btn { opacity: 0; transform: translateY(18px); }

  /* entrada escalonada do conteúdo quando o slide fica ativo */
  .slide.active .c-eyebrow,
  .slide.active .c-title,
  .slide.active .c-text,
  .slide.active .btn {
    opacity: 1;
    transform: translateY(0);
    transition: opacity .7s ease, transform .7s ease;
  }
  .slide.active .c-title { transition-delay: .12s; }
  .slide.active .c-text { transition-delay: .22s; }
  .slide.active .btn { transition-delay: .32s; }

  .c-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.35);
    background: rgba(0,0,0,.25);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s ease, border-color .15s ease;
    z-index: 3;
  }
  .c-arrow:hover { background: rgba(0,0,0,.5); border-color: #fff; }
  .c-arrow.prev { left: 18px; }
  .c-arrow.next { right: 18px; }

  .c-dots {
    position: absolute;
    bottom: 22px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 10px;
    z-index: 3;
  }
  .c-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 0;
    background: rgba(255,255,255,.4);
    cursor: pointer;
    padding: 0;
    transition: background .2s ease, width .2s ease;
  }
  .c-dot.active { background: #fff; width: 26px; border-radius: 6px; }

  @media (max-width: 560px) {
    .c-arrow { display: none; }
  }
</style>

<script>
  const root = document.querySelector('.carousel')
  if (root) {
    const slides = Array.from(root.querySelectorAll('.slide'))
    const dots = Array.from(root.querySelectorAll('.c-dot'))
    let i = 0
    let timer

    const show = (n) => {
      i = (n + slides.length) % slides.length
      slides.forEach((s, k) => s.classList.toggle('active', k === i))
      dots.forEach((d, k) => d.classList.toggle('active', k === i))
    }
    const next = () => show(i + 1)
    const prev = () => show(i - 1)
    const start = () => { timer = window.setInterval(next, 6500) }
    const reset = () => { window.clearInterval(timer); start() }

    root.querySelector('.next')?.addEventListener('click', () => { next(); reset() })
    root.querySelector('.prev')?.addEventListener('click', () => { prev(); reset() })
    dots.forEach((d) => d.addEventListener('click', () => { show(Number(d.dataset.i)); reset() }))
    root.addEventListener('mouseenter', () => window.clearInterval(timer))
    root.addEventListener('mouseleave', start)

    start()
  }
</script>
