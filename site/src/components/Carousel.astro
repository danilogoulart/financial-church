---
// Carrossel do topo, gerado automaticamente:
//  - banners manuais (Site → Carrossel)
//  - notícias marcadas como destaque
//  - 1 slide "Programação" com os 6 próximos eventos
// Sem conteúdo, mostra um slide de boas-vindas.
import { getCarousel } from '../lib/content'
import { imageUrl } from '../lib/supabase'

let slides = await getCarousel()
if (!slides.length) slides = [{ type: 'welcome' }]
---

<section class="carousel" aria-label="Destaques" aria-roledescription="carrossel">
  <div class="slides">
    {slides.map((s, i) => {
      const active = i === 0 ? ' active' : ''

      if (s.type === 'welcome') {
        return (
          <div class={`slide slide-plain${active}`}>
            <div class="slide-inner wrap">
              <p class="c-eyebrow">Bem-vindo</p>
              <h1 class="c-title">Uma casa de fé, comunhão e palavra</h1>
              <p class="c-text">Acompanhe as novidades, eventos e estudos da Igreja AD Alpha.</p>
              <a class="btn" href="/eventos">Ver programação</a>
            </div>
          </div>
        )
      }

      // banner | news | event — imagem mostrada por completo (contain) sobre
      // um fundo desfocado da própria imagem (preenche as laterais).
      const img = imageUrl(s.image)
      const eyebrow = s.type === 'news' ? 'Notícia' : s.type === 'event' ? 'Evento' : ''
      const cta = s.type === 'news' ? 'Ler notícia' : s.type === 'event' ? 'Ver evento' : 'Saiba mais'
      const hasText = eyebrow || s.title || s.subtitle
      const body = (
        <>
          <div class="slide-bg" style={`background-image: url('${img}')`}></div>
          <img class="slide-img" src={img} alt={s.title || 'Banner'} />
          {hasText && (
            <>
              <div class="slide-scrim"></div>
              <div class="slide-inner wrap">
                {eyebrow && <p class="c-eyebrow">{eyebrow}</p>}
                {s.title && <h2 class="c-title">{s.title}</h2>}
                {(s.subtitle || s.excerpt) && <p class="c-text">{s.subtitle || s.excerpt}</p>}
                {s.href && <span class="btn">{cta}</span>}
              </div>
            </>
          )}
        </>
      )

      return s.href ? (
        <a class={`slide slide-photo${active}`} href={s.href}>{body}</a>
      ) : (
        <div class={`slide slide-photo${active}`}>{body}</div>
      )
    })}
  </div>

  {slides.length > 1 && (
    <>
      <button class="c-arrow prev" aria-label="Slide anterior">‹</button>
      <button class="c-arrow next" aria-label="Próximo slide">›</button>
      <div class="c-dots">
        {slides.map((_, i) => (
          <button class:list={['c-dot', { active: i === 0 }]} data-i={i} aria-label={`Ir para o slide ${i + 1}`}></button>
        ))}
      </div>
    </>
  )}
</section>

<style>
  .carousel {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: -40px;
    margin-bottom: 80px;
    overflow: hidden;
    background: #0e0f11;
  }
  .slides { position: relative; height: clamp(460px, 74vh, 640px); }
  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #14161a;
    display: flex;
    align-items: center;
    text-decoration: none;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 1s ease, transform 6s ease;
    pointer-events: none;
  }
  .slide.active { opacity: 1; transform: scale(1); pointer-events: auto; }

  /* Slides com imagem: imagem por completo (contain) + fundo desfocado */
  .slide-photo { align-items: flex-end; }
  .slide-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(24px) brightness(0.45);
    transform: scale(1.2);
    z-index: 0;
  }
  .slide-img {
    position: absolute;
    inset: 0;
    margin: auto;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    z-index: 1;
  }
  .slide-scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    background: linear-gradient(to top, rgba(10,11,13,.92), rgba(10,11,13,0));
    z-index: 2;
  }
  .slide-photo .slide-inner { position: relative; z-index: 3; padding-bottom: 40px; }

  /* Fundo elegante para slides sem imagem (eventos / boas-vindas) */
  .slide-plain {
    background-image:
      radial-gradient(1000px 380px at 82% -10%, rgba(190,196,204,.16), transparent 60%),
      linear-gradient(150deg, #1a1c1f 0%, #2b2f34 55%, #17191c 100%);
  }

  .slide-inner { color: #fff; max-width: var(--wrap); width: 100%; }
  .c-eyebrow {
    text-transform: uppercase;
    letter-spacing: .22em;
    font-size: 13px;
    font-weight: 600;
    color: #cfd3d8;
    margin: 0 0 14px;
  }
  .c-title {
    font-family: var(--serif);
    font-size: clamp(32px, 5.5vw, 56px);
    line-height: 1.08;
    color: #fff;
    max-width: 16ch;
    margin: 0;
  }
  .c-text {
    font-size: clamp(16px, 2.2vw, 20px);
    color: #dfe2e6;
    max-width: 560px;
    margin: 16px 0 0;
  }

  /* entrada suave do conteúdo ao ativar */
  .slide .slide-inner > * { opacity: 0; transform: translateY(16px); }
  .slide.active .slide-inner > * {
    opacity: 1;
    transform: translateY(0);
    transition: opacity .7s ease, transform .7s ease;
  }
  .slide.active .c-title { transition-delay: .1s; }
  .slide.active .c-text { transition-delay: .2s; }
  .slide.active .btn { transition-delay: .3s; }

  .c-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.35);
    background: rgba(0,0,0,.25);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s ease, border-color .15s ease;
    z-index: 3;
  }
  .c-arrow:hover { background: rgba(0,0,0,.5); border-color: #fff; }
  .c-arrow.prev { left: 18px; }
  .c-arrow.next { right: 18px; }

  .c-dots {
    position: absolute;
    bottom: 18px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 10px;
    z-index: 3;
  }
  .c-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 0;
    background: rgba(255,255,255,.4);
    cursor: pointer;
    padding: 0;
    transition: background .2s ease, width .2s ease;
  }
  .c-dot.active { background: #fff; width: 26px; border-radius: 6px; }

  @media (max-width: 640px) {
    .c-arrow { display: none; }
  }
</style>

<script>
  const root = document.querySelector('.carousel')
  if (root) {
    const slides = Array.from(root.querySelectorAll('.slide'))
    const dots = Array.from(root.querySelectorAll('.c-dot'))

    if (slides.length > 1) {
      let i = 0
      let timer

      const show = (n) => {
        i = (n + slides.length) % slides.length
        slides.forEach((s, k) => s.classList.toggle('active', k === i))
        dots.forEach((d, k) => d.classList.toggle('active', k === i))
      }
      const next = () => show(i + 1)
      const prev = () => show(i - 1)
      const start = () => { timer = window.setInterval(next, 6500) }
      const reset = () => { window.clearInterval(timer); start() }

      root.querySelector('.next')?.addEventListener('click', () => { next(); reset() })
      root.querySelector('.prev')?.addEventListener('click', () => { prev(); reset() })
      dots.forEach((d) => d.addEventListener('click', () => { show(Number(d.dataset.i)); reset() }))
      root.addEventListener('mouseenter', () => window.clearInterval(timer))
      root.addEventListener('mouseleave', start)

      start()
    }
  }
</script>
