---
import Base from '../../layouts/Base.astro'
import { getEvents } from '../../lib/content'
import { imageUrl } from '../../lib/supabase'
import { fmtDateTime } from '../../lib/format'

const events = await getEvents({ upcomingOnly: true })
---

<Base title="Eventos" description="Agenda de cultos, congressos e encontros da Igreja AD Alpha.">
  <div class="section-head">
    <h1>Próximos eventos</h1>
  </div>
  {events.length === 0 ? (
    <div class="empty">Nenhum evento agendado no momento.</div>
  ) : (
    <div class="grid">
      {events.map((e) => (
        <div class="card">
          {e.cover_path && <img class="thumb" src={imageUrl(e.cover_path)} alt={e.title} />}
          <div class="body">
            <span class="tag">Evento</span>
            <h3>{e.title}</h3>
            <span class="meta">{fmtDateTime(e.starts_at)}{e.location ? ` · ${e.location}` : ''}</span>
            {e.description && <p>{e.description}</p>}
          </div>
        </div>
      ))}
    </div>
  )}
</Base>
