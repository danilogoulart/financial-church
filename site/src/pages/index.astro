---
import Base from '../layouts/Base.astro'
import Carousel from '../components/Carousel.astro'
import { getPosts, getUpcomingEvents } from '../lib/content'
import { imageUrl } from '../lib/supabase'
import { scheduleLabel } from '../lib/events'

const posts = await getPosts(3)
const events = await getUpcomingEvents(6)

const ADDR = 'Rua Rio de Janeiro, N°6 - Praia Linda, São Pedro Da Aldeia - Rio de Janeiro - Brasil'
const mapSrc = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3676.868579716404!2d-42.1670715!3d-22.8443512!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x97139de411598f%3A0x5794f89b05ef838d!2sAssembleia%20de%20Deus%20Alpha%20minist%C3%A9rio%20central%20praia%20linda!5e0!3m2!1spt-BR!2sbr!4v1784787546643!5m2!1spt-BR!2sbr'

const cults = [
  { day: 'Domingo', desc: 'Culto de Louvor e Adoração' },
  { day: 'Terça', desc: 'Culto da Palavra Viva' },
  { day: 'Quinta', desc: 'Quinta Fire' },
  { day: 'Consagração', desc: 'Momento de busca' }
]
---

<Base>
  <Carousel />

  <section>
    <div class="section-head">
      <h2>Programação</h2>
      <a class="link-all" href="/eventos">ver programação completa →</a>
    </div>
    {events.length === 0 ? (
      <div class="empty">Nenhum evento agendado no momento.</div>
    ) : (
      <div class="grid">
        {events.map((e) => (
          <a class="card" href={`/eventos/${e.slug}`}>
            {e.cover_path && <img class="thumb-full" src={imageUrl(e.cover_path)} alt={e.title} />}
            <div class="body">
              <span class="tag">Evento</span>
              <h3>{e.title}</h3>
              <span class="meta">🗓️ {scheduleLabel(e)}</span>
              {e.location && <span class="meta">📍 {e.location}</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="about">
    <div>
      <h2>Quem somos</h2>
      <p>
        Somos uma comunidade cristã que se reúne para adorar a Deus, cultivar
        relacionamentos e servir a comunidade. Aqui há lugar para toda a família —
        crianças, jovens e adultos.
      </p>
      <p>Seja para uma visita ou para fazer parte, você será muito bem recebido.</p>
      <a class="btn" href="/quem-somos">Conheça nossa história</a>
    </div>
    <div class="about-media">
      <img src="/logo.png" alt="Igreja AD Alpha" />
    </div>
  </section>

  <section>
    <div class="section-head"><h2>Nossos encontros</h2></div>
    <div class="cults-grid">
      {cults.map((c) => (
        <div class="cult">
          <div class="day">{c.day}</div>
          <div class="desc">{c.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Últimas notícias</h2>
      <a class="link-all" href="/noticias">ver todas →</a>
    </div>
    {posts.length === 0 ? (
      <div class="empty">Nenhuma notícia publicada ainda.</div>
    ) : (
      <div class="grid">
        {posts.map((p) => (
          <a class="card" href={`/noticias/${p.slug}`}>
            {p.cover_path && <img class="thumb" src={imageUrl(p.cover_path)} alt={p.title} />}
            <div class="body">
              <h3>{p.title}</h3>
              {p.excerpt && <p>{p.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section id="localizacao">
    <div class="section-head"><h2>Onde estamos</h2></div>
    <div class="location">
      <div class="info">
        <p>{ADDR}</p>
        <a class="btn" href="https://maps.app.goo.gl/HUY63ezV4G5SaNn17" target="_blank" rel="noopener">
          Abrir no Google Maps
        </a>
      </div>
      <iframe
        class="map-embed"
        src={mapSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa da localização"
      ></iframe>
    </div>
  </section>
</Base>
