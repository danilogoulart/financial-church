---
import Base from '../layouts/Base.astro'
import Carousel from '../components/Carousel.astro'
import { getPosts, getEvents } from '../lib/content'
import { imageUrl } from '../lib/supabase'
import { fmtDateTime } from '../lib/format'

const posts = await getPosts(3)
const events = await getEvents({ upcomingOnly: true, limit: 3 })

const ADDR = 'Rua Rio de Janeiro, N°6 - Praia Linda, São Pedro Da Aldeia - Rio de Janeiro - Brasil'
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(ADDR)}&output=embed`

// Cultos da semana. Ajuste os rótulos/horários como preferir.
const cults = [
  { day: 'Domingo', desc: 'Culto de celebração' },
  { day: 'Terça', desc: 'Estudo da Palavra' },
  { day: 'Quinta', desc: 'Culto de oração' },
  { day: 'Consagração', desc: 'Momento de busca' }
]
---

<Base>
  <Carousel />

  <section class="about">
    <div>
      <h2>Quem somos</h2>
      <p>
        Somos uma comunidade cristã que se reúne para adorar a Deus, cultivar
        relacionamentos e servir a cidade. Aqui há lugar para toda a família —
        crianças, jovens e adultos.
      </p>
      <p>Seja para uma visita ou para fazer parte, você será muito bem recebido.</p>
      <a class="btn" href="/noticias">Conheça nossas atividades</a>
    </div>
    <div class="about-media">
      <img src="/logo.png" alt="Igreja AD Alpha" />
    </div>
  </section>

  <section>
    <div class="section-head"><h2>Nossos encontros</h2></div>
    <div class="cults-grid">
      {cults.map((c) => (
        <div class="cult">
          <div class="day">{c.day}</div>
          <div class="desc">{c.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Últimas notícias</h2>
      <a class="link-all" href="/noticias">ver todas →</a>
    </div>
    {posts.length === 0 ? (
      <div class="empty">Nenhuma notícia publicada ainda.</div>
    ) : (
      <div class="grid">
        {posts.map((p) => (
          <a class="card" href={`/noticias/${p.slug}`}>
            {p.cover_path && <img class="thumb" src={imageUrl(p.cover_path)} alt={p.title} />}
            <div class="body">
              <h3>{p.title}</h3>
              {p.excerpt && <p>{p.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section>
    <div class="section-head">
      <h2>Próximos eventos</h2>
      <a class="link-all" href="/eventos">ver todos →</a>
    </div>
    {events.length === 0 ? (
      <div class="empty">Nenhum evento agendado no momento.</div>
    ) : (
      <div class="grid">
        {events.map((e) => (
          <div class="card">
            {e.cover_path && <img class="thumb" src={imageUrl(e.cover_path)} alt={e.title} />}
            <div class="body">
              <span class="tag">Evento</span>
              <h3>{e.title}</h3>
              <span class="meta">{fmtDateTime(e.starts_at)}{e.location ? ` · ${e.location}` : ''}</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <section id="localizacao">
    <div class="section-head"><h2>Onde estamos</h2></div>
    <div class="location">
      <div class="info">
        <p>{ADDR}</p>
        <a class="btn" href={`https://www.google.com/maps?q=${encodeURIComponent(ADDR)}`} target="_blank" rel="noopener">
          Abrir no Google Maps
        </a>
      </div>
      <iframe
        class="map-embed"
        src={mapSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa da localização"
      ></iframe>
    </div>
  </section>
</Base>
